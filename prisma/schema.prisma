model IoTSensor {
  id              String   @id @default(cuid())
  tenantId        String
  shipmentId      String?
  sensorType      String   // temperature, humidity, gps, shock, light, co2
  deviceId        String
  deviceName      String?
  manufacturer    String?
  lastReading     String?  // JSON
  lastReadingAt   DateTime?
  batteryLevel    Float?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  shipment  Shipment?       @relation(fields: [shipmentId], references: [id])
  readings  IoTReading[]
  @@unique([tenantId, deviceId])
  @@index([tenantId])
}

model IoTReading {
  id              String   @id @default(cuid())
  sensorId        String
  readingType     String
  value           Float
  unit            String
  latitude        Float?
  longitude       Float?
  isAlert         Boolean  @default(false)
  alertType       String?
  timestamp       DateTime @default(now())
  createdAt       DateTime @default(now())

  sensor IoTSensor @relation(fields: [sensorId], references: [id])
  @@index([sensorId])
  @@index([sensorId, timestamp])
  @@index([isAlert])
}

model QcVerification {
  id                  String   @id @default(cuid())
  tenantId            String
  certBodyId          String?  // External certification body
  verificationType    String   // eudr, organic, fairtrade, rainforest, utz, 4c
  entityType          String   // farmer, farmland, batch, shipment
  entityId            String
  status              String   @default("requested") // requested, scheduled, in_progress, passed, failed, expired
  scheduledDate       DateTime?
  completedDate       DateTime?
  inspectorName       String?
  inspectorCertNo     String?
  findings            String?  // JSON
  certificateUrl      String?
  validUntil          DateTime?
  notes               String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  @@index([tenantId])
  @@index([tenantId, verificationType])
  @@index([tenantId, status])
}

model AnalyticsReport {
  id              String   @id @default(cuid())
  tenantId        String
  createdBy       String?
  reportType      String   // eudr_compliance, supply_chain, financial, quality, sustainability, deforestation
  title           String
  description     String?
  dateRangeStart  DateTime?
  dateRangeEnd    DateTime?
  parameters      String?  // JSON
  data            String?  // JSON aggregated data
  chartConfig     String?  // JSON chart configuration
  fileUrl         String?  // Exported PDF/Excel URL
  format          String   @default("json") // json, pdf, xlsx
  status          String   @default("generating") // generating, ready, failed
  isScheduled     Boolean  @default(false)
  scheduleCron    String?
  lastGeneratedAt DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  @@index([tenantId])
  @@index([tenantId, reportType])
}
