generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ════════════════════════════════════════════════════════════════
// PLATFORM-LEVEL MODELS (No tenantId — global data)
// ════════════════════════════════════════════════════════════════

model PlatformUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("super_admin")
  roleId       String?
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  platformRole PlatformRole? @relation(fields: [roleId], references: [id])
}

model Tenant {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  legalName      String?
  taxId          String?
  logoUrl        String?
  currency       String   @default("VND")
  currencySymbol String   @default("₫")
  language          String   @default("vi")
  timezone          String   @default("Asia/Ho_Chi_Minh")
  dateFormat        String   @default("DD/MM/YYYY")
  locale            String   @default("vi-VN")
  countryCode       String   @default("VN")
  region            String?
  supportedLanguages String   @default("[\"vi\",\"en\"]")
  dateFormatShort   String   @default("DD/MM/YYYY")
  dateFormatLong    String   @default("DD MMMM YYYY")
  numberFormat      String   @default("vi-VN")
  measurementUnit   String   @default("metric")
  enabledModules    String   @default("{}")
  country           String   @default("VN")
  eudrCompliant     Boolean  @default(false)
  certifications String?
  plan           String   @default("starter")
  maxUsers       Int      @default(10)
  maxFarmers     Int      @default(500)
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  paypalSubscriptionId   String?
  subscriptionPlanId     String?
  subscriptionStatus     String?  @default("inactive") // inactive, active, past_due, cancelled, trialing
  subscriptionProvider   String?  // stripe, paypal
  billingEmail           String?
  whiteLabelDomain       String?
  whiteLabelConfig       String?  // JSON for white-label settings
  commodityTypes         String   @default("[\"coffee\"]") // JSON array: coffee, cocoa, palm_oil, soy
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users                  User[]
  farmers                Farmer[]
  farmLands              FarmLand[]
  cultivations           Cultivation[]
  nurseries              Nursery[]
  landPreparations       LandPreparation[]
  cropMonitorings        CropMonitoring[]
  fertilizerApplications FertilizerApplication[]
  pestDiseaseManagements PestDiseaseManagement[]
  harvestTraceabilities  HarvestTraceability[]
  collectionCentres      CollectionCentre[]
  procurementRecords     ProcurementRecord[]
  processingJobOrders    ProcessingJobOrder[]
  processingStageRecords ProcessingStageRecord[]
  certAssessments        CertAssessment[]
  coffeeInspections      CoffeeInspection[]
  smartContracts         SmartContract[]
  marketplaceListings    MarketplaceListing[]
  saleTransactions       SaleTransaction[]
  hashChainBlocks        HashChainBlock[]
  auditLogs              AuditLog[]
  qrVerifications        QRVerification[]
  soilAnalyses           SoilAnalysis[]
  lots                   Lot[]
  subscription           Subscription?
  eudrCompliances        EudrCompliance[]
  exportDocuments        ExportDocument[]
  shipments              Shipment[]
  buyers                 Buyer[]
  tradingContracts       TradingContract[]
  trackingUpdates        TrackingUpdate[]
  deforestationAssessments DeforestationAssessment[]
  apiKeys                ApiKey[]
  webhookEndpoints       WebhookEndpoint[]
  complianceBookings     ComplianceBooking[]
  iotSensors             IoTSensor[]
  qcVerifications        QcVerification[]
  analyticsReports       AnalyticsReport[]
}

model PlatformSetting {
  id          String   @id @default(cuid())
  category    String   // "business", "platform", "api", "theme", "mobile", "security", "email", "notification"
  key         String
  value       String
  valueType   String   @default("string") // "string", "number", "boolean", "json"
  description String?
  isPublic    Boolean  @default(false) // Whether tenant can read this setting
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@unique([category, key])
}

model Subscription {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  planId          String   // Reference to plan definition
  planName        String
  status          String   @default("active") // "active", "suspended", "cancelled", "trial"
  startDate       DateTime
  endDate         DateTime?
  trialEndDate    DateTime?
  maxUsers        Int      @default(10)
  maxFarmers      Int      @default(500)
  maxFarmLands    Int      @default(1000)
  storageLimitMb  Int      @default(500)
  apiCallsLimit   Int      @default(10000)
  features        String   @default("{}") // JSON object of feature flags
  amount          Float?
  currency        String?
  billingCycle    String?  // "monthly", "yearly"
  autoRenew       Boolean  @default(true)
  lastPaymentDate DateTime?
  nextPaymentDate DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  @@index([tenantId])
  @@index([status])
}

model PlatformRole {
  id          String   @id @default(cuid())
  name        String   @unique // "super_admin", "support_lead", "support_agent", "billing_admin", "readonly"
  displayName String
  description String?
  permissions String   @default("{}") // JSON object of permission flags
  isSystem    Boolean  @default(false) // Cannot be deleted if true
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  platformUsers PlatformUser[]
}

model Module {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  icon        String?
  color       String?
  category    String?
  version     String   @default("1.0.0")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ════════════════════════════════════════════════════════════════
// TENANT-LEVEL MODELS
// ════════════════════════════════════════════════════════════════

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String
  name         String
  role         String   @default("farmer")
  phone        String?
  avatar       String?
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  @@unique([email, tenantId])
  @@index([tenantId])
}

model Farmer {
  id                      String   @id @default(cuid())
  tenantId                String
  createdBy               String?
  enrollmentDate          DateTime @default(now())
  enrollmentPlace         String?
  farmerCode              String?
  isCertified             Boolean  @default(false)
  certificationType       String?
  yearOfICS               String?
  cooperative             String?
  fullName                String
  firstName               String?
  lastName                String?
  middleName              String?
  contactNumber           String
  farmerPhoto             String?
  nationalIdType          String?
  nationalIdNo            String?
  idProofPhoto            String?
  ekycConsent             Boolean  @default(false)
  gender                  String?
  dob                     DateTime?
  age                     Int?
  education               String?
  maritalStatus           String?
  spouseName              String?
  noOfFamilyMembers       Int?
  housingOwnership        String?
  houseType               String?
  yearsOfFarmingExperience Int?
  email                   String?
  country                 String?
  province                String?
  district                String?
  commune                 String?
  village                 String?
  zipCode                 String?
  latitude                Float?
  longitude               Float?
  creditScore             Float?
  loanTaken               Boolean  @default(false)
  loanTakenFrom           String?
  loanAmount              Float?
  loanPurpose             String?
  loanInterest            Float?
  loanSecurity            Boolean  @default(false)
  cropInsurance           Boolean  @default(false)
  lifeInsurance           Boolean  @default(false)
  healthInsurance         Boolean  @default(false)
  smartphoneOwnership     Boolean  @default(false)
  gapTrainingAttended     Boolean  @default(false)
  isActive                Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  tenant                    Tenant                    @relation(fields: [tenantId], references: [id])
  farmLands                 FarmLand[]
  cultivations              Cultivation[]
  landPreparations          LandPreparation[]
  cropMonitorings           CropMonitoring[]
  fertilizerApplications    FertilizerApplication[]
  pestDiseaseManagements    PestDiseaseManagement[]
  harvestTraceabilities     HarvestTraceability[]
  procurementRecords        ProcurementRecord[]
  nurseries                 Nursery[]
  certAssessments           CertAssessment[]
  coffeeInspections         CoffeeInspection[]
  smartContracts            SmartContract[]
  marketplaceListings       MarketplaceListing[]
  eudrCompliances          EudrCompliance[]
  @@unique([farmerCode, tenantId])
  @@index([tenantId])
  @@index([tenantId, province])
}

model FarmLand {
  id                       String   @id @default(cuid())
  tenantId                 String
  farmerId                 String
  createdBy                String?
  farmName                 String
  plotBlockId              String?
  totalLandHolding         Float?
  altitude                 Float?
  agroEcologicalZone       String?
  latitude                 Float?
  longitude                Float?
  landOwnership            String?
  soilType                 String?
  irrigationSource         String?
  irrigationType           String?
  waterSource              String?
  powerSource              String?
  noOfTrees                Int?
  shadeTreeSpecies         String?
  shadeTreeDensity         Int?
  fullTimeWorkers          Int?
  partTimeWorkers          Int?
  seasonalWorkers          Int?
  familyWorkers            Int?
  estYield                 Float?
  conversionCertType       String?
  currentConversionStatus  String?
  fertilityStatus          String?
  childLabourPolicy        Boolean  @default(false)
  minimumWageCompliance    Boolean  @default(false)
  ppeAvailable             Boolean  @default(false)
  isActive                 Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  tenant                Tenant                @relation(fields: [tenantId], references: [id])
  farmer                Farmer                @relation(fields: [farmerId], references: [id])
  cultivations          Cultivation[]
  landPreparations      LandPreparation[]
  cropMonitorings       CropMonitoring[]
  fertilizerApplications FertilizerApplication[]
  pestDiseaseManagements PestDiseaseManagement[]
  harvestTraceabilities HarvestTraceability[]
  polygonGeoJson        String?
  boundaryArea          Float?
  geoCenterLat          Float?
  geoCenterLng          Float?
  soilAnalyses          SoilAnalysis[]
  certAssessments       CertAssessment[]
  coffeeInspections     CoffeeInspection[]
  deforestationAssessments DeforestationAssessment[]
  eudrCompliances          EudrCompliance[]
  @@index([tenantId])
  @@index([tenantId, farmerId])
}

model Cultivation {
  id                      String   @id @default(cuid())
  tenantId                String
  farmerId                String
  farmLandId              String
  createdBy               String?
  farmPlotName            String
  plotBlockId             String?
  cropCategory            String?
  intercroppingSpecies    String?
  harvestSeason           String?
  cultivatedCrop          String?
  cropVariety             String?
  coffeeSpecies           String?
  cultivationArea         Float?
  plantingSpacing         Float?
  treeDensity             Int?
  sowingDate              DateTime?
  estYield                String?
  intendedProcessingMethod String?
  irrigationMethod        String?
  shadeCover              Int?
  latitude                Float?
  longitude               Float?
  seedSource              String?
  isSeedTreated           Boolean  @default(false)
  treatmentDetails        String?
  seedType                String?
  seedQuantity            Float?
  seedPrice               Float?
  seedCost                Float?
  intercroppingEnabled    Boolean  @default(false)
  intercroppingPartner    String?
  intercroppingRatio      String?
  intercroppingScheme     String?
  isPrimaryCrop           Boolean  @default(true)
  isActive                Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  farmer     Farmer     @relation(fields: [farmerId], references: [id])
  farmLand   FarmLand   @relation(fields: [farmLandId], references: [id])
  @@index([tenantId])
  @@index([tenantId, farmerId])
  @@index([tenantId, farmLandId])
}

model Nursery {
  id                  String   @id @default(cuid())
  tenantId            String
  farmerId            String?
  createdBy           String?
  nurseryName         String
  nurseryCode         String?
  location            String?
  province            String?
  district            String?
  commune             String?
  latitude            Float?
  longitude           Float?
  nurseryType         String?
  capacity            Int?
  currentStock        Int?
  species             String?
  variety             String?
  seedSource          String?
  plantingDate        DateTime?
  expectedReadyDate   DateTime?
  germinationRate     Float?
  survivalRate        Float?
  healthStatus        String?
  notes               String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  farmer  Farmer?  @relation(fields: [farmerId], references: [id])
  @@index([tenantId])
  @@index([tenantId, farmerId])
}

model LandPreparation {
  id                  String   @id @default(cuid())
  tenantId            String
  farmerId            String
  farmLandId          String
  createdBy           String?
  preparationDate     DateTime?
  preparationType     String?
  method              String?
  equipmentUsed       String?
  laborCount          Int?
  laborCost           Float?
  materialsUsed       String?
  materialCost        Float?
  totalCost           Float?
  soilPhBefore        Float?
  soilPhAfter         Float?
  organicMatterPct    Float?
  notes               String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  farmer   Farmer   @relation(fields: [farmerId], references: [id])
  farmLand FarmLand @relation(fields: [farmLandId], references: [id])
  @@index([tenantId])
  @@index([tenantId, farmerId])
}

model CropMonitoring {
  id                  String   @id @default(cuid())
  tenantId            String
  farmerId            String
  farmLandId          String
  cultivationId       String?
  createdBy           String?
  monitoringDate      DateTime?
  monitoringType      String?
  growthStage         String?
  plantHeight         Float?
  canopyDiameter      Float?
  leafColor           String?
  healthScore         Float?
  pestPressure        String?
  diseaseSymptoms     String?
  weatherCondition    String?
  temperature         Float?
  rainfall            Float?
  humidity            Float?
  soilMoisture        Float?
  alertTriggered      Boolean  @default(false)
  alertType           String?
  alertSeverity       String?
  remedialAction      String?
  photoUrl            String?
  notes               String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  farmer      Farmer      @relation(fields: [farmerId], references: [id])
  farmLand    FarmLand    @relation(fields: [farmLandId], references: [id])
  @@index([tenantId])
  @@index([tenantId, farmerId])
  @@index([tenantId, alertTriggered])
}

model FertilizerApplication {
  id                  String   @id @default(cuid())
  tenantId            String
  farmerId            String
  farmLandId          String
  cultivationId       String?
  createdBy           String?
  applicationDate     DateTime?
  fertilizerType      String?
  fertilizerName      String?
  nutrientContent     String?
  applicationRate     Float?
  unit                String?
  totalQuantity       Float?
  applicationMethod   String?
  costPerUnit         Float?
  totalCost           Float?
  weatherAtApplication String?
  appliedBy           String?
  isOrganic           Boolean  @default(false)
  certificationNumber String?
  notes               String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  farmer   Farmer   @relation(fields: [farmerId], references: [id])
  farmLand FarmLand @relation(fields: [farmLandId], references: [id])
  @@index([tenantId])
  @@index([tenantId, farmerId])
}

model PestDiseaseManagement {
  id                  String   @id @default(cuid())
  tenantId            String
  farmerId            String
  farmLandId          String
  cultivationId       String?
  createdBy           String?
  detectionDate       DateTime?
  pestOrDisease       String?
  type                String?
  severity            String?
  affectedArea        Float?
  affectedTrees       Int?
  symptoms            String?
  treatmentMethod     String?
  treatmentProduct    String?
  dosage              String?
  applicationDate     DateTime?
  followUpDate        DateTime?
  outcome             String?
  cost                Float?
  preventionMeasures  String?
  photoUrl            String?
  notes               String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  farmer   Farmer   @relation(fields: [farmerId], references: [id])
  farmLand FarmLand @relation(fields: [farmLandId], references: [id])
  @@index([tenantId])
  @@index([tenantId, farmerId])
}

model HarvestTraceability {
  id                  String   @id @default(cuid())
  tenantId            String
  cultivationId       String?
  farmerId            String
  farmLandId          String
  createdBy           String?
  plannedHarvestDate  DateTime?
  plotBlockId         String?
  coffeeVariety       String?
  estimatedYield      String?
  actualHarvestDate   DateTime?
  harvestMethod       String?
  cherryRipeness      Float?
  harvestLabourCost   Float?
  sampleWeight        Float?
  sampleArea          Float?
  sampleYield         Float?
  estimatedYieldPerHa Float?
  processingMethod    String?
  dryingMethod        String?
  dryingDurationDays  Int?
  targetMoisture      Float?
  moistureContent     Float?
  defectiveBeans      Float?
  foreignMatter       Float?
  cupScore            Float?
  batchId             String?
  coffeeVarietyAtBatch String?
  processingStage     String?
  batchTimestamp      DateTime?
  location            String?
  actor               String?
  batchNotes          String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  farmer     Farmer     @relation(fields: [farmerId], references: [id])
  farmLand   FarmLand   @relation(fields: [farmLandId], references: [id])
  @@index([tenantId])
  @@index([tenantId, farmerId])
  @@index([tenantId, batchId])
}

model CollectionCentre {
  id                String   @id @default(cuid())
  tenantId          String
  centreId          String?
  centreName        String
  centreGpsLat      Float?
  centreGpsLng      Float?
  province          String?
  district          String?
  commune           String?
  address           String?
  managerName       String?
  contactNumber     String?
  storageCapacityKg Float?
  scaleType         String?
  operatingHours    String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant            Tenant            @relation(fields: [tenantId], references: [id])
  procurementRecords ProcurementRecord[]
  @@index([tenantId])
}

model ProcurementRecord {
  id                    String   @id @default(cuid())
  tenantId              String
  collectionCentreId    String?
  cultivationId         String?
  farmerId              String
  farmLandId            String?
  createdBy             String?
  procurementId         String?
  procurementDate       DateTime?
  batchId               String?
  coffeeType            String?
  coffeeVariety         String?
  grossWeight           Float?
  tareWeight            Float?
  netWeight             Float?
  moistureContentAtGate Float?
  adjustedNetWeight     Float?
  cherryRipenessGrade   String?
  defects               Float?
  purchasePricePerKg    Float?
  totalPurchaseAmount   Float?
  priceBasis            String?
  certPremiumApplied    Float?
  paymentMethod         String?
  paymentStatus         String?
  paymentDate           DateTime?
  transportId           String?
  vehicleNumber         String?
  driverName            String?
  departureTime         DateTime?
  arrivalTime           DateTime?
  destination           String?
  transportCost         Float?
  transportNotes        String?
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  farmer           Farmer           @relation(fields: [farmerId], references: [id])
  collectionCentre CollectionCentre? @relation(fields: [collectionCentreId], references: [id])
  @@index([tenantId])
  @@index([tenantId, farmerId])
  @@index([tenantId, batchId])
}

model ProcessingJobOrder {
  id                    String   @id @default(cuid())
  tenantId              String
  createdBy             String?
  jobOrderId            String?
  processingDate        DateTime?
  batchIdInput          String?
  coffeeTypeInput       String?
  coffeeVarietyInput    String?
  inputQuantityKg       Float?
  processingMethod      String?
  targetOutputProduct   String?
  operatorName          String?
  plantFacilityName     String?
  inputWeightKg         Float?
  finalOutputWeightKg   Float?
  overallOutturn        Float?
  totalProcessingCost   Float?
  costPerKg             Float?
  finalMoistureContent  Float?
  cupScore              Float?
  cuppingNotes          String?
  qcApprovedBy          String?
  qcApprovalDate        DateTime?
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  processingStages   ProcessingStageRecord[]
  @@index([tenantId])
  @@index([tenantId, batchIdInput])
}

model ProcessingStageRecord {
  id                  String   @id @default(cuid())
  tenantId            String
  jobOrderId          String
  stageType           String?
  stageDate           DateTime?
  inputWeight         Float?
  outputWeight        Float?
  durationMinutes     Int?
  temperature         Float?
  humidity            Float?
  machineUsed         String?
  operatorName        String?
  qualityCheckPassed  Boolean  @default(false)
  notes               String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant    Tenant            @relation(fields: [tenantId], references: [id])
  jobOrder  ProcessingJobOrder @relation(fields: [jobOrderId], references: [id])
  @@index([tenantId])
  @@index([tenantId, jobOrderId])
}

model CertAssessment {
  id                      String   @id @default(cuid())
  tenantId                String
  farmerId                String?
  farmLandId              String?
  createdBy               String?
  assessmentId            String?
  assessmentDate          DateTime?
  certificationStandard   String?
  certifyingBody          String?
  assessmentType          String?
  scope                   String?
  status                  String?
  score                   Float?
  maxScore                Float?
  findings                String?
  nonConformities         String?
  correctiveActions       String?
  validFrom               DateTime?
  validUntil              DateTime?
  certificateNumber       String?
  certificateDocumentUrl  String?
  notes                   String?
  isActive                Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  farmer   Farmer?   @relation(fields: [farmerId], references: [id])
  farmLand FarmLand? @relation(fields: [farmLandId], references: [id])
  @@index([tenantId])
  @@index([tenantId, farmerId])
}

model CoffeeInspection {
  id                  String   @id @default(cuid())
  tenantId            String
  farmerId            String?
  farmLandId          String?
  batchId             String?
  createdBy           String?
  inspectionId        String?
  inspectionDate      DateTime?
  inspectorName       String?
  inspectorCertNo     String?
  inspectionType      String?
  inspectionStandard  String?
  sampleSize          Float?
  moistureContent     Float?
  defectCount         Float?
  foreignMatter       Float?
  screenSize          String?
  color               String?
  aroma               String?
  taste               String?
  body                String?
  acidity             String?
  aftertaste          String?
  cupScore            Float?
  overallGrade        String?
  passFail             String?
  remarks             String?
  photoUrl            String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  farmer   Farmer?   @relation(fields: [farmerId], references: [id])
