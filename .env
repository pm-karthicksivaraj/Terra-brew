# Environment Configuration — Terra Brew Platform
# Copy to .env.local for local development

# ═══ DATABASE ═══
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/terra_brew"

# ═══ AUTHENTICATION ═══
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-in-production-min-32-chars-long!"

# ═══ ENCRYPTION ═══
# AES-256-GCM key for PII encryption (32 bytes base64-encoded)
PII_ENCRYPTION_KEY="Y2hhbmdlLW1lLWluLXByb2R1Y3Rpb24tMzJieXRlcw=="

# HMAC key for QR code signing
HMAC_SECRET_KEY="change-me-hmac-secret-key-production"

# ═══ REDIS (Upstash) ═══
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ═══ FILE STORAGE ═══
S3_ENDPOINT=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="terra-brew"
S3_REGION="auto"

# ═══ PLATFORM ═══
PLATFORM_ADMIN_EMAIL="admin@terrabrew.platform"
PLATFORM_ADMIN_PASSWORD="ChangeMe!2024Secure"
