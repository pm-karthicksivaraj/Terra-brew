{
  "expo": {
    "name": "Terra Brew",
    "slug": "terra-brew-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6B4226"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.terrabrew.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6B4226"
      },
      "package": "com.terrabrew.mobile",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "NFC"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Terra Brew to access your camera for QR/barcode scanning."
        }
      ],
      [
        "expo-location",
        {
          "locationPermission": "Allow Terra Brew to access your location for farm geo-tagging."
        }
      ],
      [
        "expo-barcode-scanner",
        {
          "cameraPermission": "Allow Terra Brew to access your camera for QR/barcode scanning."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png"
        }
      ]
    ]
  }
}
